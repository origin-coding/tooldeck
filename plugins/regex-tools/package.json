{
  "name": "@tooldeck/regex-tools",
  "version": "1.1.0",
  "private": true,
  "description": "Regex tools plugin for Tooldeck.",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "generate": "tooldeck-plugin generate",
    "generate:types": "pnpm generate",
    "check": "tooldeck-plugin check",
    "build": "tooldeck-plugin build --bundler vite",
    "typecheck": "pnpm generate && tsc --noEmit",
    "inspect": "tooldeck-plugin inspect"
  },
  "dependencies": {
    "@tooldeck/plugin-tools": "workspace:*",
    "@tooldeck/sdk-node": "workspace:*",
    "@tooldeck/vite-plugin": "workspace:*"
  }
}
