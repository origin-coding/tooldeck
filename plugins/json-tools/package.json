{
  "name": "@tooldeck/json-tools",
  "version": "1.1.0",
  "private": true,
  "description": "JSON tools plugin for Tooldeck.",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "generate": "pnpm --dir ../.. --filter @tooldeck/plugin-tools build && node ../../packages/plugin-tools/dist/tooldeck-plugin.js generate",
    "generate:types": "pnpm generate",
    "check": "pnpm generate && node ../../packages/plugin-tools/dist/tooldeck-plugin.js check",
    "build": "pnpm generate && vite build --configLoader runner && node ../../packages/plugin-tools/dist/tooldeck-plugin.js check --built",
    "typecheck": "pnpm generate && tsc --noEmit"
  },
  "dependencies": {
    "@tooldeck/plugin-tools": "workspace:*",
    "@tooldeck/sdk-node": "workspace:*"
  }
}
