{
  "name": "@tooldeck/storage",
  "version": "0.0.0",
  "private": true,
  "description": "SQLite storage layer for Tooldeck.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build --configLoader runner && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@tooldeck/protocol": "workspace:*",
    "drizzle-orm": "1.0.0-rc.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1"
  }
}
