{
  "name": "@tooldeck/plugin-tools",
  "version": "1.1.0",
  "description": "Development tools for Tooldeck plugins.",
  "bin": {
    "tooldeck-plugin": "dist/tooldeck-plugin.js",
    "tooldeck-plugin-types": "dist/generate-command-types.js"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build --configLoader runner && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tooldeck/protocol": "workspace:*",
    "ajv": "^8.20.0",
    "citty": "^0.2.2",
    "json-schema-to-typescript": "^15.0.4",
    "scule": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1"
  }
}
