{
  "name": "@tooldeck/plugin-tools",
  "version": "1.2.0",
  "description": "Development tools for Tooldeck plugins.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/origin-coding/tooldeck.git",
    "directory": "packages/plugin-tools"
  },
  "bin": {
    "tooldeck-plugin": "bin/tooldeck-plugin.js",
    "tooldeck-plugin-types": "bin/tooldeck-plugin-types.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build --configLoader runner && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tooldeck/plugin-package": "workspace:*",
    "@tooldeck/protocol": "workspace:*",
    "ajv": "^8.20.0",
    "citty": "^0.2.2",
    "consola": "^3.4.2",
    "json-schema-to-typescript": "^15.0.4",
    "scule": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1"
  }
}
