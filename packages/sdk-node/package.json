{
  "name": "@tooldeck/sdk-node",
  "version": "1.3.0",
  "description": "SDK types and helpers for Tooldeck plugins.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/origin-coding/tooldeck.git",
    "directory": "packages/sdk-node"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build --configLoader runner && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@tooldeck/protocol": "workspace:*"
  }
}
