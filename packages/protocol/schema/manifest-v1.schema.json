{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "https://tooldeck.dev/schemas/manifest-v1.schema.json",
  "title": "Tooldeck Plugin Manifest v1",
  "description": "Manifest schema for Tooldeck Plugin Protocol v1.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "name", "version", "runtime"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference used by editors."
    },
    "schemaVersion": {
      "const": "1.0",
      "description": "Tooldeck Plugin Protocol manifest version."
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*)+$",
      "description": "Globally unique plugin id. Use lowercase ASCII dot-separated segments. Each segment may contain lowercase letters, digits, and hyphens."
    },
    "name": {
      "$ref": "#/definitions/localizedString"
    },
    "description": {
      "$ref": "#/definitions/localizedString"
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "description": "Plugin version."
    },
    "runtime": {
      "$ref": "#/definitions/runtime"
    },
    "defaultLocale": {
      "type": "string",
      "minLength": 1
    },
    "locales": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "contributes": {
      "$ref": "#/definitions/contributes"
    }
  },
  "definitions": {
    "localizedString": {
      "description": "Display text, either plain or localized by key.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["key", "default"],
          "properties": {
            "key": {
              "type": "string",
              "minLength": 1
            },
            "default": {
              "type": "string"
            }
          }
        }
      ]
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "entry"],
      "properties": {
        "kind": {
          "const": "node"
        },
        "entry": {
          "type": "string",
          "minLength": 1,
          "description": "Plugin runtime entry path, relative to the manifest file."
        }
      }
    },
    "contributes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/command"
          }
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*)+$",
          "description": "Globally unique command id. Use lowercase ASCII dot-separated segments. Each segment may contain lowercase letters, digits, and hyphens."
        },
        "title": {
          "$ref": "#/definitions/localizedString"
        },
        "description": {
          "$ref": "#/definitions/localizedString"
        },
        "x-ui": {
          "$ref": "#/definitions/commandUi"
        },
        "inputSchema": {
          "$ref": "#/definitions/tooldeckInputJsonSchema"
        },
        "outputSchema": {
          "$ref": "#/definitions/tooldeckJsonSchema"
        }
      }
    },
    "commandUi": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "layout": {
          "enum": ["stacked", "split"],
          "description": "Desktop layout hint for the command input and output areas. Defaults to stacked."
        }
      }
    },
    "tooldeckInputJsonSchema": {
      "allOf": [
        {
          "$ref": "#/definitions/tooldeckJsonSchema"
        },
        {
          "type": "object",
          "properties": {
            "x-ui": {
              "$ref": "#/definitions/jsonSchemaUi"
            },
            "properties": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/definitions/tooldeckInputFieldJsonSchemaDefinition"
              }
            }
          }
        }
      ]
    },
    "tooldeckInputFieldJsonSchemaDefinition": {
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "$ref": "#/definitions/tooldeckInputFieldJsonSchema"
        }
      ]
    },
    "tooldeckInputFieldJsonSchema": {
      "allOf": [
        {
          "$ref": "#/definitions/tooldeckJsonSchema"
        },
        {
          "type": "object",
          "properties": {
            "x-ui": {
              "$ref": "#/definitions/jsonSchemaFieldUi"
            }
          }
        }
      ]
    },
    "tooldeckJsonSchema": {
      "allOf": [
        {
          "$ref": "https://json-schema.org/draft-07/schema"
        },
        {
          "type": "object",
          "properties": {
            "x-i18n": {
              "$ref": "#/definitions/jsonSchemaI18n"
            }
          }
        }
      ]
    },
    "jsonSchemaI18n": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "enumLabels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "jsonSchemaUi": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fieldOrder": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "jsonSchemaFieldUi": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["control"],
          "properties": {
            "control": {
              "const": "text"
            },
            "placeholder": {
              "$ref": "#/definitions/localizedString"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["control"],
          "properties": {
            "control": {
              "const": "textarea"
            },
            "rows": {
              "type": "number"
            },
            "placeholder": {
              "$ref": "#/definitions/localizedString"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["control"],
          "properties": {
            "control": {
              "const": "number"
            },
            "placeholder": {
              "$ref": "#/definitions/localizedString"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["control"],
          "properties": {
            "control": {
              "const": "checkbox"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["control"],
          "properties": {
            "control": {
              "const": "radio"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["control"],
          "properties": {
            "control": {
              "const": "select"
            },
            "placeholder": {
              "$ref": "#/definitions/localizedString"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["control"],
          "properties": {
            "control": {
              "const": "checkboxGroup"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["control"],
          "properties": {
            "control": {
              "const": "multiSelect"
            },
            "placeholder": {
              "$ref": "#/definitions/localizedString"
            }
          }
        }
      ]
    }
  }
}
