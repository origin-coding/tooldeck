{
  "name": "@tooldeck/protocol",
  "version": "1.1.0",
  "description": "Toolbox Plugin Protocol types for Tooldeck.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "schema"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema/manifest-v1.schema.json": "./schema/manifest-v1.schema.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build --configLoader runner && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/json-schema": "^7.0.15"
  }
}
