{
  "name": "@tooldeck/host-node",
  "version": "1.1.2",
  "private": true,
  "description": "Node.js plugin host for loading and running Tooldeck plugins.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build --configLoader runner && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@tooldeck/protocol": "workspace:*",
    "@tooldeck/runtime-node": "workspace:*",
    "@tooldeck/sdk-node": "workspace:*",
    "@tooldeck/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.1"
  }
}
