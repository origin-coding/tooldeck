{
  "name": "tooldeck",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "builtin-plugins:list": "node scripts/builtin-plugins.mjs list",
    "builtin-plugins:build": "node scripts/builtin-plugins.mjs build",
    "builtin-plugins:stage": "node scripts/builtin-plugins.mjs stage",
    "changeset": "changeset",
    "check:desktop-boundaries": "pnpm --filter @tooldeck/desktop check:boundaries",
    "smoke:cli": "pnpm --filter @tooldeck/cli smoke:built",
    "dev:cli": "pnpm --filter @tooldeck/cli dev",
    "dev:desktop": "pnpm --filter @tooldeck/desktop dev",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "test": "turbo run test",
    "test:run": "turbo run test -- --run",
    "publish:npm-trusted": "node scripts/publish-npm-trusted.mjs",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "tsx": "^4.20.6",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
