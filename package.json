{
  "name": "tooldeck",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "builtin-plugins:list": "node scripts/builtin-plugins.mjs list",
    "builtin-plugins:build": "node scripts/builtin-plugins.mjs build",
    "builtin-plugins:stage": "node scripts/builtin-plugins.mjs stage",
    "check:desktop-boundaries": "pnpm --filter @tooldeck/desktop check:boundaries",
    "smoke:cli": "pnpm --filter @tooldeck/cli smoke:built",
    "dev:cli": "pnpm --filter @tooldeck/cli dev",
    "dev:desktop": "pnpm --filter @tooldeck/desktop dev",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "test": "turbo run test",
    "test:run": "turbo run test -- --run"
  },
  "devDependencies": {
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "tsx": "^4.20.6",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
