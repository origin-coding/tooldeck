{
  "name": "tooldeck",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "builtin-plugins:list": "node scripts/builtin-plugins.mjs list",
    "builtin-plugins:build": "node scripts/builtin-plugins.mjs build",
    "builtin-plugins:stage": "node scripts/builtin-plugins.mjs stage",
    "changeset": "changeset",
    "check:desktop-boundaries": "pnpm --filter @tooldeck/desktop check:boundaries",
    "smoke:cli": "pnpm --filter @tooldeck/cli smoke:built",
    "dev:cli": "pnpm --filter @tooldeck/cli dev",
    "dev:desktop": "pnpm --filter @tooldeck/desktop dev",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "test": "turbo run test",
    "test:run": "turbo run test -- --run",
    "publish:npm-trusted": "node scripts/publish-npm-trusted.mjs",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "tsx": "^4.20.6",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
