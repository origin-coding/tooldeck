{
  "name": "@tooldeck/desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Electron desktop app for Tooldeck.",
  "author": {
    "name": "origin-coding"
  },
  "type": "module",
  "main": ".vite/build/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs",
    "dist": "pnpm --dir ../.. --filter @tooldeck/hello-world --filter @tooldeck/json-tools build && pnpm build && electron-builder",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ant-design/pro-components": "3.1.12-0",
    "antd": "^6.4.3",
    "fuse.js": "^7.4.2",
    "i18next": "^26.3.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tooldeck/core": "workspace:*",
    "@tooldeck/host-node": "workspace:*",
    "@tooldeck/protocol": "workspace:*",
    "@tooldeck/shared": "workspace:*",
    "@tooldeck/storage": "workspace:*",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "dev.tooldeck.desktop",
    "productName": "Tooldeck",
    "directories": {
      "output": "release"
    },
    "files": [
      ".vite/build/**",
      ".vite/renderer/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../plugins/hello-world",
        "to": "plugins/hello-world",
        "filter": [
          "manifest.json",
          "package.json",
          "dist/**",
          "locales/**"
        ]
      },
      {
        "from": "../../plugins/json-tools",
        "to": "plugins/json-tools",
        "filter": [
          "manifest.json",
          "package.json",
          "dist/**",
          "locales/**"
        ]
      }
    ],
    "asar": true
  }
}
