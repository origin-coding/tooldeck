{
  "name": "@tooldeck/cli",
  "version": "0.0.0",
  "private": true,
  "description": "Command-line interface for Tooldeck.",
  "bin": {
    "tooldeck": "./dist/index.js"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "pretest": "pnpm --filter @tooldeck/hello-world --filter @tooldeck/json-tools build",
    "test": "vitest run test"
  },
  "dependencies": {
    "@tooldeck/core": "workspace:*",
    "@tooldeck/hello-world": "workspace:*",
    "@tooldeck/host-node": "workspace:*",
    "@tooldeck/json-tools": "workspace:*",
    "@tooldeck/protocol": "workspace:*",
    "@tooldeck/shared": "workspace:*",
    "@tooldeck/storage": "workspace:*",
    "citty": "^0.2.2",
    "consola": "^3.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.1"
  }
}
