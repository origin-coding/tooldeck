{
  "name": "@tooldeck/cli",
  "version": "1.1.0",
  "description": "Command-line interface for Tooldeck.",
  "bin": {
    "tooldeck": "dist/index.js"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "vite build",
    "postbuild": "pnpm --dir ../.. builtin-plugins:stage -- --out apps/cli/dist/plugins --skip-build",
    "smoke:built": "node scripts/smoke-built.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run test"
  },
  "dependencies": {
    "citty": "^0.2.2",
    "cli-table3": "^0.6.5",
    "consola": "^3.4.2",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@tooldeck/preferences": "workspace:*",
    "@tooldeck/runtime-node": "workspace:*",
    "@tooldeck/hello-world": "workspace:*",
    "@tooldeck/host-node": "workspace:*",
    "@tooldeck/json-tools": "workspace:*",
    "@tooldeck/protocol": "workspace:*",
    "@tooldeck/regex-tools": "workspace:*",
    "@tooldeck/shared": "workspace:*",
    "@tooldeck/storage": "workspace:*",
    "@types/node": "^25.9.1"
  }
}
