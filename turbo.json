{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "generate"],
      "outputs": ["dist/**", ".vite/**"]
    },
    "generate": {
      "dependsOn": ["^build"],
      "outputs": ["src/generated/**"]
    },
    "typecheck": {
      "dependsOn": ["^build", "generate"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build", "generate"],
      "outputs": []
    },
    "check": {
      "dependsOn": ["^build", "generate"],
      "outputs": []
    },
    "smoke:built": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
